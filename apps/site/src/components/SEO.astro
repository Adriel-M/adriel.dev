---
import { SEO as Seo } from 'astro-seo'

import siteConfig from '@/libs/siteConfig'

type BasicData = {
  type: 'basic'
  title: string
  noindex?: boolean
}

type FullData = {
  type: 'full'
  title: string
  description: string
  ogImage: string
}

type Post = Omit<FullData, 'type'> & {
  type: 'post'
  article: {
    publishedTime: string
    modifiedTime?: string
  }
}

export type SeoData = BasicData | FullData | Post

interface Props {
  seoData: SeoData
}

const { seoData } = Astro.props

const titleTemplate = `%s | ${siteConfig.title}`
---

{
  seoData.type === 'basic' ? (
    <Seo title={seoData.title} titleTemplate={titleTemplate} noindex={seoData.noindex} />
  ) : (
    <Seo
      title={seoData.title}
      titleTemplate={titleTemplate}
      description={seoData.description}
      openGraph={{
        basic: {
          title: seoData.title,
          type: seoData.type === 'post' ? 'article' : 'website',
          image: seoData.ogImage,
        },
        ...(seoData.type === 'post' ? { article: seoData.article } : {}),
      }}
    />
  )
}
