---
import type { SeoData } from '@/components/SEO.astro'
import RootLayout from '@/layouts/RootLayout.astro'

const origin = new URL(Astro.request.url).origin

const seoData: SeoData = {
  type: 'full',
  title: 'All Posts',
  description: `All blog posts for ${origin}`,
  ogImage: new URL('posts/og.png', origin).toString(),
}
---

<RootLayout seoData={seoData}>
  <div>
    <div class="py-6">
      <h1
        class="text-3xl leading-9 font-extrabold tracking-tight text-gray-900 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14"
      >
        All Posts
      </h1>
    </div>
    <div class="flex flex-col lg:flex-row lg:space-x-24">
      <slot />
    </div>
  </div>
</RootLayout>
