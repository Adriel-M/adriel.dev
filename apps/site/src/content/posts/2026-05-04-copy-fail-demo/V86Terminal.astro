---
import '@xterm/xterm/css/xterm.css'

interface Props {
  biosUrl: string
  vgaBiosUrl: string
  bzimageUrl: string
  initrdUrl: string
}

const { biosUrl, vgaBiosUrl, bzimageUrl, initrdUrl } = Astro.props
---

<v86-terminal
  data-bios-url={biosUrl}
  data-vga-bios-url={vgaBiosUrl}
  data-bzimage-url={bzimageUrl}
  data-initrd-url={initrdUrl}
>
  <div class="my-6 overflow-hidden rounded-lg border border-zinc-800">
    <div class="flex items-center gap-1.5 border-b border-zinc-800 bg-black px-4 py-2.5">
      <span class="inline-block size-3 rounded-full bg-red-400"></span>
      <span class="inline-block size-3 rounded-full bg-yellow-400"></span>
      <span class="inline-block size-3 rounded-full bg-green-400"></span>
      <span class="ml-2 font-mono text-xs text-zinc-400 select-none">demo@copyfail:~$</span>
    </div>
    <div class="relative h-[400px] bg-black">
      <div
        class="absolute inset-0 z-10 flex flex-col items-center justify-center gap-3"
        data-v86-start-overlay
      >
        <button
          class="rounded bg-zinc-100 px-4 py-2 text-sm font-medium text-zinc-900 transition hover:bg-blue-500 hover:text-white focus:ring-2 focus:ring-white/50 focus:outline-none"
          data-v86-start-btn
        >
          Start Demo
        </button>
        <p class="text-xs text-zinc-400">Downloads ~15 MB</p>
      </div>
      <div
        class="absolute inset-0 flex items-center justify-center text-xs text-zinc-500"
        data-v86-status
      >
      </div>
      <div class="h-full" data-v86-terminal></div>
    </div>
  </div>
</v86-terminal>

<script>
  import wasmUrl from 'v86/build/v86.wasm?url'
  import { FitAddon } from '@xterm/addon-fit'

  class V86Terminal extends HTMLElement {
    connectedCallback() {
      const container = this.querySelector<HTMLElement>('[data-v86-terminal]')
      const status = this.querySelector<HTMLElement>('[data-v86-status]')
      const overlay = this.querySelector<HTMLElement>('[data-v86-start-overlay]')
      const startBtn = this.querySelector<HTMLButtonElement>('[data-v86-start-btn]')
      const setStatus = (msg: string) => {
        if (status) status.textContent = msg
      }
      if (!container || !overlay || !startBtn) return

      startBtn.addEventListener('click', async () => {
        overlay.style.display = 'none'
        setStatus('Loading emulator…')

        const [{ V86 }, { Terminal }] = await Promise.all([import('v86'), import('@xterm/xterm')])

        setStatus('Booting kernel…')
        const fitAddon = new FitAddon()
        const emu = new V86({
          wasm_path: wasmUrl,
          bios: { url: this.dataset.biosUrl! },
          vga_bios: { url: this.dataset.vgaBiosUrl! },
          bzimage: { url: this.dataset.bzimageUrl! },
          initrd: { url: this.dataset.initrdUrl! },
          cmdline: 'console=ttyS0 tsc=reliable rdinit=/init',
          autostart: true,
          memory_size: 256 * 1024 * 1024,
          vga_memory_size: 8 * 1024 * 1024,
          disable_speaker: true,
          serial_console: {
            type: 'xtermjs',
            container,
            xterm_lib: function (_: unknown, options: ConstructorParameters<typeof Terminal>[0]) {
              const term = new Terminal(options)
              term.loadAddon(fitAddon)
              return term
            },
          },
        })

        emu.add_listener('emulator-loaded', () => {
          setStatus('')
          fitAddon.fit()
          const onResize = () => fitAddon.fit()
          window.addEventListener('resize', onResize)
          new ResizeObserver(onResize).observe(container)
        })

        emu.add_listener('download-error', (e: { file_name: string }) =>
          setStatus(`Download error: ${e.file_name}`)
        )
      })
    }
  }

  customElements.define('v86-terminal', V86Terminal)
</script>
