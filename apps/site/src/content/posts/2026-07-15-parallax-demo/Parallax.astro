---
import type { ImageMetadata } from 'astro'

import ResponsivePicture from '@/components/ResponsivePicture.astro'

interface Props {
  src: ImageMetadata
  alt: string
}

const { src, alt } = Astro.props

const hasCaption = Astro.slots.has('default')
---

<figure class="parallax-figure">
  <div class="parallax">
    <ResponsivePicture src={src} alt={alt} />
  </div>
  {
    hasCaption && (
      <figcaption class="parallax-caption mt-2 text-right text-sm text-gray-500">
        <slot />
      </figcaption>
    )
  }
</figure>

<style>
  .parallax-figure {
    margin: 0;
    /* Space the caption off the next band so its attribution doesn't read
       as a label for the image below it. */
    margin-block-end: 2.5rem;
  }

  .parallax {
    position: relative;
    overflow: hidden;
    height: 80vh;

    /* Name a timeline that tracks this element's trip through the viewport. */
    view-timeline-name: --parallax-tl;
    view-timeline-axis: block;
  }

  /* ResponsivePicture nests the image as .parallax > photo-swipe > a > picture > img,
     so stretch every wrapper to fill the band before the img can cover it. */
  .parallax > :global(photo-swipe),
  .parallax :global(photo-swipe > a),
  .parallax :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .parallax :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;

    /* Oversize the layer so the drift never exposes an empty edge. The scale
       must be at least 1 + 2·offset/100, so 1.4x covers the ±20% translate. */
    scale: 1.4;
  }

  /* Only engines that understand scroll-driven animations get the CSS path.
     Gating this keeps a browser without view-timeline support from attaching
     the animation to the default (time) timeline — with `auto` duration and
     `both` fill it would snap the image to a keyframe and override the
     JS-driven translate below, so the two paths would disagree. */
  @supports (animation-timeline: view()) {
    .parallax :global(img) {
      /* Drive the keyframes off scroll position instead of time. */
      animation: parallax auto linear both;
      animation-timeline: --parallax-tl;
      animation-range: cover;
      will-change: translate;
    }
  }

  @keyframes parallax {
    from {
      translate: 0 -20%;
    }
    to {
      translate: 0 20%;
    }
  }

  .parallax-caption :global(p) {
    margin: 0;
  }

  /* Honor users who opt out of motion: no drift, no oversize. */
  @media (prefers-reduced-motion: reduce) {
    .parallax :global(img) {
      animation: none;
      scale: 1;
    }
  }
</style>

<script>
  // Progressive enhancement. Chrome/Edge 115+ and Safari 26 run the parallax
  // entirely in CSS via the scroll-driven animation above. Firefox (still
  // behind a flag) and older engines land here: a rAF-throttled scroll handler
  // reproduces the same -20% → +20% drift, so the effect degrades to
  // JavaScript instead of to a static image.
  const nativeSupport = typeof CSS !== 'undefined' && CSS.supports('animation-timeline', 'view()')
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  if (!nativeSupport && !reduceMotion.matches) {
    const layers = Array.from(document.querySelectorAll<HTMLElement>('.parallax')).flatMap(
      (box) => {
        const img = box.querySelector<HTMLImageElement>('img')
        if (!img) return []
        return [{ box, img }]
      }
    )

    if (layers.length) {
      let ticking = false

      const update = () => {
        ticking = false
        const viewport = window.innerHeight
        for (const { box, img } of layers) {
          const rect = box.getBoundingClientRect()
          // 0 as the element enters the bottom edge, 1 as it leaves the top —
          // this mirrors the CSS `animation-range: cover`.
          const progress = Math.min(
            1,
            Math.max(0, (viewport - rect.top) / (viewport + rect.height))
          )
          img.style.translate = `0 ${(progress * 2 - 1) * 20}%`
        }
      }

      const onScroll = () => {
        if (ticking) return
        ticking = true
        requestAnimationFrame(update)
      }

      addEventListener('scroll', onScroll, { passive: true })
      addEventListener('resize', onScroll, { passive: true })
      update()
    }
  }
</script>
